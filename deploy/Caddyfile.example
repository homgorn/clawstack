example.com {
    encode zstd gzip

    @assets {
        path /styles.css /app.js /favicon.svg /favicon.ico /og-card.svg /robots.txt /sitemap.xml /llms.txt /site.webmanifest /docs/*
    }

    reverse_proxy 127.0.0.1:8000

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "SAMEORIGIN"
    }
}
