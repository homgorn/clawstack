{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenClaw Starter Config",
  "type": "object",
  "required": [
    "gateway",
    "env",
    "agents",
    "skills"
  ],
  "properties": {
    "gateway": {
      "type": "object",
      "required": [
        "bind",
        "port",
        "auth"
      ],
      "properties": {
        "bind": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "auth": {
          "type": "object",
          "required": [
            "required",
            "secret"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "secret": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "env": {
      "type": "object",
      "required": [
        "file"
      ],
      "properties": {
        "file": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "agents": {
      "type": "object",
      "required": [
        "defaults",
        "list"
      ],
      "properties": {
        "defaults": {
          "type": "object",
          "properties": {
            "model": {
              "type": "object",
              "required": [
                "primary",
                "fallbacks"
              ],
              "properties": {
                "primary": {
                  "type": "string"
                },
                "fallbacks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 1
                }
              },
              "additionalProperties": true
            },
            "heartbeat": {
              "type": "object",
              "required": [
                "model",
                "interval"
              ],
              "properties": {
                "model": {
                  "type": "string"
                },
                "interval": {
                  "type": "integer",
                  "minimum": 1
                },
                "directPolicy": {
                  "type": "string",
                  "enum": [
                    "allow",
                    "block"
                  ]
                }
              },
              "additionalProperties": true
            },
            "sandbox": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string"
                },
                "workspaceAccess": {
                  "type": "string"
                },
                "docker": {
                  "type": "object",
                  "properties": {
                    "network": {
                      "type": "string"
                    },
                    "image": {
                      "type": "string"
                    },
                    "memory": {
                      "type": "string"
                    },
                    "cpus": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "list": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "workspace"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "default": {
                "type": "boolean"
              },
              "workspace": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "skills": {
      "type": "object",
      "required": [
        "autoLoad",
        "directory",
        "sandboxFirstRun"
      ],
      "properties": {
        "autoLoad": {
          "type": "boolean"
        },
        "directory": {
          "type": "string"
        },
        "sandboxFirstRun": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
